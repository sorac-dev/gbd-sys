# Configuración general de la aplicación
APP_NAME="GDB Pagos"
APP_URL=http://localhost/gdb/public
APP_ENV=development
APP_DEBUG=true

# Configuración de la base de datos (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gdb_pagos
DB_USER=root
DB_PASS=

# Configuración de sesiones de PHP
SESSION_NAME=gdb_session
SESSION_LIFETIME=7200
